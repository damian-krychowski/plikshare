{
  "name": "plikshare",
  "version": "1.0.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build --configuration production --output-path=../PlikShare/wwwroot",
    "watch": "ng build --watch --configuration development --output-path=../PlikShare/wwwroot",
    "build-prod": "ng build --configuration production --output-path=./dist",
    "build-prod-dev": "ng build --configuration production --output-path=../PlikShare/wwwroot",
    "update": "ng update @angular/cli @angular/core",
    "build-elements-prod": "ng run PlikShare:build-elements:production --output-path=./dist/browser/elements && node merge-elements.js \"./dist/browser/elements\"",
    "build-elements-prod-dev": "ng run PlikShare:build-elements:production --output-path=../PlikShare/wwwroot/browser/elements && node merge-elements.js \"../PlikShare/wwwroot/browser/elements\""
  },
  "private": true,
  "dependencies": {
    "@angular/animations": "^21.2.7",
    "@angular/cdk": "^21.2.5",
    "@angular/common": "^21.2.7",
    "@angular/compiler": "^21.2.7",
    "@angular/core": "^21.2.7",
    "@angular/elements": "^21.2.7",
    "@angular/forms": "^21.2.7",
    "@angular/localize": "^21.2.7",
    "@angular/material": "^21.2.5",
    "@angular/platform-browser": "^21.2.7",
    "@angular/platform-browser-dynamic": "^21.2.7",
    "@angular/router": "^21.2.7",
    "@lexical/code": "^0.42.0",
    "@lexical/history": "^0.42.0",
    "@lexical/html": "^0.42.0",
    "@lexical/list": "^0.42.0",
    "@lexical/markdown": "^0.42.0",
    "@lexical/react": "^0.42.0",
    "@lexical/rich-text": "^0.42.0",
    "@lexical/table": "^0.42.0",
    "@lexical/utils": "^0.42.0",
    "@popperjs/core": "^2.11.8",
    "base-x": "^5.0.1",
    "clipboard": "^2.0.11",
    "dompurify": "^3.3.3",
    "exifr": "^7.1.3",
    "lexical": "^0.42.0",
    "marked": "^17.0.5",
    "mermaid": "^11.14.0",
    "ngx-markdown": "^21.1.0",
    "ngx-toastr": "^20.0.5",
    "protobufjs": "^8.0.0",
    "qrcode": "^1.5.4",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "rxjs": "~7.8.2",
    "tslib": "^2.8.1"
  },
  "devDependencies": {
    "@angular-devkit/build-angular": "^21.2.6",
    "@angular/cli": "^21.2.6",
    "@angular/compiler-cli": "^21.2.7",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "concat": "^1.0.3",
    "fs-extra": "^11.3.4",
    "rimraf": "^6.1.3",
    "typescript": "^5.9.2"
  }
}
